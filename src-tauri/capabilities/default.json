{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "gh",
          "cmd": "gh",
          "args": true,
          "sidecar": false
        },
        {
          "name": "curl",
          "cmd": "curl",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "epik-sidecar",
          "cmd": "binaries/epik-sidecar",
          "args": true,
          "sidecar": true
        }
      ]
    }
  ]
}
