{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Epik",
  "version": "0.1.0",
  "identifier": "app.epik.local",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm run build:sidecar && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Epik",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/epik-sidecar"]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
